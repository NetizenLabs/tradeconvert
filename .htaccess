RewriteEngine On

# Redirect WWW to Non-WWW
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Handle Tool Pretty URLs (Mapped to /tools/ folder)
RewriteRule ^pressure$ tools/pressure.html [L]
RewriteRule ^length$ tools/length.html [L]
RewriteRule ^electrical$ tools/electrical.html [L]
RewriteRule ^concrete$ tools/concrete.html [L]
RewriteRule ^lumber$ tools/lumber.html [L]
RewriteRule ^weight$ tools/weight.html [L]
RewriteRule ^temperature$ tools/temperature.html [L]
RewriteRule ^volume$ tools/volume.html [L]
RewriteRule ^embed$ tools/embed.html [L]

# Handle Static Root Pages
RewriteRule ^about$ about.html [L]
RewriteRule ^contact$ contact.html [L]
RewriteRule ^privacy$ privacy.html [L]

# Handle Blog
RewriteRule ^blog/?$ blog/index.html [L]
RewriteRule ^blog/what-water-pressure-is-too-high$ blog/what-water-pressure-is-too-high.html [L]

# Internal .html hiding (fallback)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L,QSA]
