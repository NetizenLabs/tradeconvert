RewriteEngine On

# Redirect WWW to Non-WWW
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# SEO 301 Redirects for Old URLs (fixing 404s)
RewriteRule ^volume-converter(?:\.html)?/?$ /volume/ [R=301,L]
RewriteRule ^concrete-calculator(?:\.html)?/?$ /concrete/ [R=301,L]
RewriteRule ^length-converter(?:\.html)?/?$ /length/ [R=301,L]
RewriteRule ^lumber-reference(?:\.html)?/?$ /lumber/ [R=301,L]
RewriteRule ^electrical-converter(?:\.html)?/?$ /electrical/ [R=301,L]
RewriteRule ^temperature-converter(?:\.html)?/?$ /temperature/ [R=301,L]
RewriteRule ^pressure-converter(?:\.html)?/?$ /pressure/ [R=301,L]
RewriteRule ^pressure/psi-to-bar(?:\.html)?/?$ /pressure/ [R=301,L]
RewriteRule ^drywall-calculator(?:\.html)?/?$ /drywall/ [R=301,L]
RewriteRule ^drywall-estimator(?:\.html)?/?$ /drywall/ [R=301,L]
RewriteRule ^paint-calculator(?:\.html)?/?$ /paint/ [R=301,L]
RewriteRule ^paint-estimator(?:\.html)?/?$ /paint/ [R=301,L]
RewriteRule ^roofing-calculator(?:\.html)?/?$ /roofing/ [R=301,L]
RewriteRule ^stair-calculator(?:\.html)?/?$ /stair/ [R=301,L]
RewriteRule ^stair-layout(?:\.html)?/?$ /stair/ [R=301,L]
RewriteRule ^torque-converter(?:\.html)?/?$ /torque/ [R=301,L]
RewriteRule ^weight-converter(?:\.html)?/?$ /weight/ [R=301,L]
RewriteRule ^tile-calculator(?:\.html)?/?$ /tile/ [R=301,L]
RewriteRule ^excavation-calculator(?:\.html)?/?$ /excavation/ [R=301,L]
RewriteRule ^conduit-fill-calculator(?:\.html)?/?$ /conduit-fill/ [R=301,L]
RewriteRule ^voltage-drop-calculator(?:\.html)?/?$ /voltage-drop/ [R=301,L]
RewriteRule ^privacy(?:\.html)?/?$ /privacy/ [R=301,L]
RewriteRule ^favicon\.ico$ /assets/favicon.png [R=301,L]
RewriteRule ^search$ / [R=301,L]

# SEO 301 Redirects for Blog URLs (fixing 404s)
RewriteRule ^blog/board-feet-estimation-guide(?:\.html)?/?$ /blog/board-feet-calculator-lumber-estimation-2026/ [R=301,L]
RewriteRule ^blog/circuit-breaker-sizing-nec-80-rule(?:\.html)?/?$ /blog/circuit-breaker-sizing-guide-2026/ [R=301,L]

# Serve sitemap.xml dynamically via sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Handle Embed
RewriteRule ^embed$ tools/embed.html [L]

# Internal .html hiding (fallback)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L,QSA]
