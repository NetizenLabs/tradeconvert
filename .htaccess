RewriteEngine On

# Redirect WWW to Non-WWW
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# SEO 301 Redirects for Old URLs (fixing 404s)
RewriteRule ^volume-converter/?$ /volume/ [R=301,L]
RewriteRule ^blog/board-feet-estimation-guide/?$ /blog/board-feet-calculator-lumber-estimation-2026/ [R=301,L]
RewriteRule ^concrete-calculator/?$ /concrete/ [R=301,L]
RewriteRule ^length-converter/?$ /length/ [R=301,L]
RewriteRule ^lumber-reference/?$ /lumber/ [R=301,L]
RewriteRule ^electrical-converter/?$ /electrical/ [R=301,L]
RewriteRule ^temperature-converter/?$ /temperature/ [R=301,L]
RewriteRule ^pressure/psi-to-bar/?$ /pressure/ [R=301,L]
RewriteRule ^privacy\.html$ /privacy/ [R=301,L]
RewriteRule ^favicon\.ico$ /assets/favicon.png [R=301,L]
RewriteRule ^search$ / [R=301,L]

# Serve sitemap.xml dynamically via sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Handle Embed
RewriteRule ^embed$ tools/embed.html [L]

# Internal .html hiding (fallback)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L,QSA]
